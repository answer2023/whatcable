        }
      }
    },
    "Legitimate USB-IF members ship cables with a non-zero vendor ID. A zeroed VID is a common counterfeit signature.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正规的 USB-IF 成员通常在线缆中使用非零 vendor ID。全零 VID 是常见的仿冒特征。"
          }
        }
      }
    },
    "Linked at %@": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "链路速度 %@"
          }
        }
      }
    },
    "Negotiation hasn't completed yet.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "协商尚未完成。"
          }
        }
