        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电器最高可提供 %1$lldW，但这条线缆额定只能承载 %2$lldW。更换线缆可以更快充电。"
          }
        }
      }
    },
