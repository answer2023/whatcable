        }
      }
    },
    "Cable has an e-marker chip (advertises its capabilities)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "线缆带有 e-marker 芯片（会声明自身能力）"
